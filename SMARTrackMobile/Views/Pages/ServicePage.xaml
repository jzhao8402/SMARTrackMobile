<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SMARTrackMobile.Views.Pages.ServicePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Service">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Resync" Clicked="OnResyncClicked" Order="Secondary" />
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Padding="20" Spacing="14">
        <Label Text="Service Countdown" FontSize="22" FontAttributes="Bold" />

        <Label x:Name="TargetLabel" TextColor="Gray" />
        <Label x:Name="TimeLeftLabel" FontSize="48" FontAttributes="Bold" />
        <Label x:Name="StatusLabel" TextColor="Gray" />

        <Button Text="Start / Reschedule Android Alarms" Clicked="OnStartClicked" />
        <Button Text="Stop Android Alarms" Clicked="OnStopClicked" />
    </VerticalStackLayout>
</ContentPage>
